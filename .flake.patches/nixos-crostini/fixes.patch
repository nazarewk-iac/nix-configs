Subject: [PATCH 4/4] fix: infinite recursion

---
 baguette.nix | 8 +++++---
 1 file changed, 5 insertions(+), 3 deletions(-)

diff --git a/baguette.nix b/baguette.nix
index 20b89c9..f7a7ced 100644
--- a/baguette.nix
+++ b/baguette.nix
@@ -137,8 +137,7 @@
       systemd.tmpfiles.settings.nixos-crostini-baguette."/usr/share/zoneinfo".L = {
